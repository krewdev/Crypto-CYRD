# Server Configuration
NODE_ENV=development
PORT=3000

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/cypher_relay
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Security
JWT_SECRET=your-secret-key-here
ENCRYPTION_KEY=your-32-char-encryption-key-here
API_KEY_SALT=your-api-key-salt

# Blockchain RPC URLs
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Contract Addresses (Update after deployment)
CYRD_TOKEN_POLYGON=0x...
CYRD_TOKEN_ARBITRUM=0x...
REDEMPTION_CONTRACT_POLYGON=0x...
REDEMPTION_CONTRACT_ARBITRUM=0x...

# Private Keys (Backend wallet for redemptions)
BACKEND_PRIVATE_KEY=0x...

# External Services
IPFS_GATEWAY=https://ipfs.io/ipfs/
PRICE_FEED_API=https://api.coingecko.com/api/v3

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log