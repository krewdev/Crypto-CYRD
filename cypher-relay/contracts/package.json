{
  "name": "cypher-relay-contracts",
  "version": "1.0.0",
  "description": "Smart contracts for Cypher Relay Dollar ($CYRD) token and redemption system",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:polygon": "hardhat run scripts/deploy.js --network polygon",
    "deploy:arbitrum": "hardhat run scripts/deploy.js --network arbitrum",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "verify": "hardhat verify"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.3",
    "@openzeppelin/contracts-upgradeable": "^4.9.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@nomicfoundation/hardhat-verify": "^1.1.1",
    "hardhat": "^2.17.2",
    "ethers": "^6.7.1",
    "dotenv": "^16.3.1"
  }
}